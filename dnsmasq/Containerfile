
ARG FEDORA_VERSION="43"
ARG DNSMASQ_VERSION="2.92"

#===============================================================================

FROM quay.io/fedora/fedora:${FEDORA_VERSION} AS builder

RUN mkdir -p /builder /scratch

###########
# dnsmasq #
###########

RUN dnf install \
        --assumeyes \
        --setopt=install_weak_deps=False \
        --nodocs \
        gcc \
        make

ARG BUILD_COPTS
ARG DNSMASQ_VERSION
RUN curl -# -L https://dnsmasq.org/dnsmasq-${DNSMASQ_VERSION}.tar.xz \
    | tar -C /builder -Jxv \
    && cd /builder/dnsmasq-${DNSMASQ_VERSION} \
    && make install DESTDIR=/scratch COPTS="${BUILD_COPTS}" \
    && setcap "cap_net_bind_service,cap_net_admin,cap_net_raw=+ep" \
        /scratch/usr/local/sbin/dnsmasq

#######################
# Setup Scratch Image #
#######################

RUN dnf install \
        --assumeyes \
        --installroot=/scratch \
        --use-host-config \
        --no-docs \
        --setopt=install_weak_deps=False \
        coreutils \
        glibc && \
    dnf clean all \
        --installroot=/scratch

RUN useradd \
        --user-group \
        --create-home \
        --shell=/bin/bash \
        --prefix=/scratch \
        --comment='dnsmasq' \
        dnsmasq

RUN chgrp dnsmasq /scratch/var/lib/misc/ && chmod 775 /scratch/var/lib/misc/

#===============================================================================

FROM scratch

ARG DNSMASQ_VERSION
ARG IMG_TITLE
LABEL org.opencontainers.image.source="https://github.com/doubleu-labs/containers"
LABEL org.opencontainers.image.authors="W Anders <w@doubleu.codes>"
LABEL org.opencontainers.image.title="${IMG_TITLE}"
LABEL org.opencontainers.image.description="DoubleU Labs dnsmasq"
LABEL org.opencontainers.image.license="MIT"
LABEL org.dnsmasq.version="${DNSMASQ_VERSION}"

COPY --from=builder /scratch /

EXPOSE 53/udp 53/tcp 67/udp 69/udp

USER dnsmasq

VOLUME [ "/var/lib/misc/dnsmasq.leases" ]

CMD [ "/usr/local/sbin/dnsmasq", "-d" ]
